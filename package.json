{
  "name": "pokemon-match-mcp",
  "version": "0.1.0",
  "description": "MCP server for Pokémon Champions battle advisor",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "data:fetch-jp": "tsx src/etl/fetch-jp-names.ts",
    "data:fetch-showdown": "tsx src/etl/fetch-showdown-champions.ts",
    "data:refresh": "pnpm data:fetch-jp && pnpm data:fetch-showdown",
    "db:seed-pokemon": "tsx src/etl/seed-pokemon.ts",
    "db:seed-champions": "tsx src/etl/seed-champions.ts",
    "db:seed-moves": "tsx src/etl/seed-moves.ts",
    "db:seed-learnsets": "tsx src/etl/seed-learnsets.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed-pokemon && pnpm db:seed-champions && pnpm db:seed-moves && pnpm db:seed-learnsets"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pkmn/data": "^0.10.7",
    "@pkmn/dex": "^0.10.7",
    "@pkmn/sim": "^0.10.7",
    "@smogon/calc": "^0.11.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  }
}
